{
  "openapi": "3.0.0",
  "info": {
    "title": "MiniBlog API",
    "version": "1.0.0",
    "description": "API para gestionar autores y posts"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/api/posts": {
      "get": {
        "summary": "Obtener todos los posts",
        "responses": {
          "200": {
            "description": "Lista de posts"
          }
        }
      },
      "post": {
        "summary": "Crear un post",
        "responses": {
          "201": {
            "description": "Post creado"
          }
        }
      }
    },
    "/api/posts/{id}": {
      "get": {
        "summary": "Obtener un post por ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post encontrado"
          },
          "404": {
            "description": "Post no encontrado"
          }
        }
      }
    }
  }
}