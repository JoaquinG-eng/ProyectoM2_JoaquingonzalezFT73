{
  "name": "rest-api-node",
  "version": "1.0.0",
  "description": "API REST para blog con Express y PostgreSQL",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "express",
    "postgresql",
    "rest-api",
    "blog",
    "node"
  ],
  "author": "Joaquín González",
  "license": "ISC",
   "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "pg": "^8.20.0",
     "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
 }